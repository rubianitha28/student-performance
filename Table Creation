SQL
SELECT subject_name, ROUND(AVG(marks), 2) as average_score
FROM marks_table m
JOIN subjects_table s ON m.subject_id = s.subject_id
GROUP BY subject_name
ORDER BY average_score DESC;
B. Identifying Top 5 Students
SQL
SELECT student_name, total_marks, 
       RANK() OVER (ORDER BY total_marks DESC) as rank
FROM (
    SELECT student_name, SUM(marks) as total_marks
    FROM marks_table m
    JOIN students_table s ON m.student_id = s.student_id
    GROUP BY student_name
) 
WHERE rank <= 5;

